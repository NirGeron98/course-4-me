{
  "name": "course4me",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@fontsource/heebo": "^5.2.8",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "framer-motion": "^12.23.0",
    "lucide-react": "^0.518.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "react-scripts": "5.0.1",
    "react-select": "^5.10.1",
    "sonner": "^2.0.7",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "no-console": [
        "warn",
        {
          "allow": [
            "warn",
            "error"
          ]
        }
      ],
      "no-warning-comments": [
        "error",
        {
          "terms": [
            "todo",
            "fixme",
            "xxx",
            "א",
            "ב",
            "ג",
            "ד",
            "ה",
            "ו",
            "ז",
            "ח",
            "ט",
            "י",
            "כ",
            "ך",
            "ל",
            "מ",
            "ם",
            "נ",
            "ן",
            "ס",
            "ע",
            "פ",
            "ף",
            "צ",
            "ץ",
            "ק",
            "ר",
            "ש",
            "ת"
          ],
          "location": "anywhere"
        }
      ],
      "no-restricted-imports": [
        "error",
        {
          "paths": [
            {
              "name": "axios",
              "message": "Do not import axios directly. Use apiFetch / useApi from src/hooks/useApi.js so every request shares abort, timeout, and Hebrew error normalization."
            }
          ]
        }
      ],
      "no-restricted-syntax": [
        "error",
        {
          "selector": "Literal[value=/\\b(rounded-lg|rounded-xl|rounded-2xl|shadow-lg|shadow-xl|shadow-2xl|duration-150|duration-200|duration-300|duration-500)\\b/]",
          "message": "Deprecated Tailwind utility is blocked. Use Phase 4 tokens: rounded-card / rounded-card-lg / rounded-button, shadow-card / shadow-card-hover / shadow-elevated, duration-ui / ease-ui."
        },
        {
          "selector": "TemplateElement[value.raw=/\\b(rounded-lg|rounded-xl|rounded-2xl|shadow-lg|shadow-xl|shadow-2xl|duration-150|duration-200|duration-300|duration-500)\\b/]",
          "message": "Deprecated Tailwind utility inside template literal is blocked. Use Phase 4 tokens instead."
        },
        {
          "selector": "JSXText[value=/[A-Za-z]{4,}/]",
          "message": "Hardcoded English text in JSX. User-facing copy must be Hebrew — if this is a non-translatable token (brand, email, code), wrap it in {'...'} to suppress."
        }
      ]
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.1"
  }
}
